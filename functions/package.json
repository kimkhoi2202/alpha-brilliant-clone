{
  "name": "functions",
  "description": "AlphaBrilliant Phase 2 AI backend (Cloud Functions)",
  "private": true,
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "node --import tsx --test test/firewall.test.ts",
    "check:parity": "node scripts/check-content-parity.mjs",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "@openai/agents": "^0.12.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "mathjs": "^15.2.0",
    "openai": "^6.45.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
