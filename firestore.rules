rules_version = '2';

// ===============================================================
// AlphaBrilliant — Firestore Security Rules
// ===============================================================
// Data model:
//   users/{uid}                         -> profile, streak, milestones (PII: email)
//   users/{uid}/progress/{lessonId}     -> per-lesson progress & mastery
//
// A learner can only ever read or write their own subtree.
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // A user owns their profile and everything nested under it (progress, etc.).
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
