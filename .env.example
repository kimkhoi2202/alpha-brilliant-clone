# Copy to `.env` (which is gitignored) and fill in your values.

# Server-side secret — NO VITE_ prefix, so it is never bundled into the browser.
# Used by the Vercel `/api` AI backend (api/*.ts) to call OpenAI.
OPENAI_API_KEY=sk-proj-your-key-here

# Firebase project id — used server-side by the `/api` routes to verify the
# caller's Firebase ID token (issuer/audience check) without firebase-admin.
FIREBASE_PROJECT_ID=fir-94b95

# Optional: override the realtime voice model the /api/realtime-token route mints
# a client secret for. Defaults to "gpt-realtime-2" when unset.
# OPENAI_REALTIME_MODEL=gpt-realtime-2

# Client feature flag. "false" => the app behaves exactly like the Phase 1 MVP
# (hand-written hints/feedback, no AI). "true" => AI features are enabled.
VITE_AI_ENABLED=false
